{
  "expo": {
    "name": "Calio",
    "slug": "calio-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "calio",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Calio necesita acceso a tu cámara para analizar tus alimentos con IA."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Calio necesita acceso a tus fotos para analizar tus alimentos."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.calio.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#D8FF2E",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.calio.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    }
  }
}
